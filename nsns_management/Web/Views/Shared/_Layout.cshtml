<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
   @*  <link rel="stylesheet" href="~/css/site.css" /> *@
    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main {
            flex: 1;
        }


        .btn-schedule {
            background-color: #7bb4dc;
            color: white;
            border-radius: 0;
            border: none;
            transition: background-color 0.3s ease; /* smooth effect */
        }

        .btn-schedule:hover {
            background-color: #e0e0e0;
            color: black;
        }
    </style>
</head>
<body>
    <!-- Header with Navigation -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <a href="https://nsns.ca" target="_blank">
                <img src="/images/nsns_logo_new.jpg" alt="NSNS" style="width: 100px; height: auto;" />
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                   
                    @if (User.IsInRole("Admin"))

                    {
                       @*  <li class="nav-item"><a class="nav-link" href="/Dashboard/Admin">Dashboard</a></li> *@
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Admin/List">Admins</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Staff/List">Staff</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Reports</a></li>
                    }

                    else if (User.IsInRole("Staff"))

                    {
                        @* <li class="nav-item"><a class="nav-link" href="/Dashboard/Staff">Dashboard</a></li> *@
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Specialty/List">Specialties</a></li>
                        <li class="nav-item"><a class="nav-link" href="/City/List">Cities</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Coach/List">Coaches</a></li>
                        <li class="nav-item"><a class="nav-link" href="/PaymentPackage/List">Packages</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Course/List">Courses</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Activity/List">Activities</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/List">Children</a></li>
                    }

                    else if (User.IsInRole("Coach"))

                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                       @*  <li class="nav-item"><a class="nav-link" href="/Dashboard/Coach">Dashboard</a></li> *@
                        <li class="nav-item"><a class="nav-link" href="/Coach/ManageCourse">My Courses</a></li>
                       @*  <li class="nav-item"><a class="nav-link" href="#">Feedbacks</a></li> *@
                        <li class="nav-item"><a class="nav-link" href="/Coach/Income">My Hours</a></li>
                    }

                    else if (User.IsInRole("Child"))

                    {
                        @* <li class="nav-item"><a class="nav-link" href="/Dashboard/Child">Dashboard</a></li> *@


                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyRegistrations">Registerations</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyConfirmations">Confirmations</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MySchedules">Schedules</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyEnrollmentsHistory">Enrollments</a></li>
                       @*  <li class="nav-item"><a class="nav-link" href="#">Notifications</a></li> *@
                        <li class="nav-item"><a class="nav-link" href="/Child/MyBalance">Balance</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyPayments">Payments</a></li>
                    }
                    @if (User.Identity.IsAuthenticated)

                    {
                        <li class="nav-item">
                            <a href="#" class="nav-link" onclick="document.getElementById('logout-form').submit();">Logout (@User.Identity.Name)</a>
                            <form id="logout-form" asp-controller="Account" asp-action="Logout" method="post" style="display: none;"></form>
                        </li>
                    }

                    <!-- Show Login if user is not logged in -->

                   @*  else

                    {
                       
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                    } *@
                </ul>
            </div>
        </nav>
    </header>

    @{
        string mainClass = "container mt-4";

        if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Home"

        && ViewContext.RouteData.Values["Action"]?.ToString() == "Index")

        {

            mainClass = "container-fluid mt-4";

        }
    }
    <!-- Main Content -->
    <main class="@mainClass w-100 ms-n4 pe-3">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="text-center mt-4">
        <p>&copy; @DateTime.UtcNow.Year - NSNS</p>
    </footer>

    <!-- Scripts -->
    @*  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>    $.ajaxSetup({ cache: false });</script> *@

    <!-- place for per-page scripts -->
    @RenderSection("Scripts", required: false)


</body>
</html>