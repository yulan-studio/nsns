<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden; /* prevent horizontal scroll */
        }

        main {
            flex: 1;
        }

        .navbar-brand img {
            max-height: 50px;
        }

        .navbar-nav .nav-link {
            padding: 0.75rem 1rem;
        }


        .btn-primary {
            background-color: #1B7BAB;
            border: 1px solid #1B7BAB;
        }

        .btn-primary:hover,
        .btn-primary:focus,
        .btn-primary:active,
        .btn-primary.active {
            background-color: #23A1E0 !important;
            border-color: #23A1E0 !important;
            box-shadow: none !important;
        }

        .btn-grey {
            background-color: #7bb4dc;
            color: white;
            border-radius: 0;
            border: none;
            padding: 0.6rem 1rem;
            transition: background-color 0.3s ease;
        }

        .btn-grey:hover {
            background-color: #e0e0e0;
            color: black;
        } 

        .btn-static-grey {
            background-color: #e0e0e0;
            color: #333;
            border: 1px solid #ccc;
        }


        .btn-static-grey:hover,
        .btn-static-grey:focus,
        .btn-static-grey:active,
        .btn-static-grey.active {
            background-color: #e0e0e0; /* same as normal */
            color: #333;
            border-color: #ccc;
            box-shadow: none;
        }

        footer {
            padding: 1rem 0;
            font-size: 0.9rem;
        }


        @@media (max-width: 768px) {

        .btn-grey {

            color: #fff;
            border: 1px solid #7bb4dc;
        }

        .btn-grey:hover {
            background-color: #7bb4dc;
            border-color: #7bb4dc;
            color: #fff;
        }

        .btn-grey:active,
        .btn-grey.active {
            background-color: #7bb4dc !important;
            border-color: #7bb4dc !important;
            color: #fff !important;
        }

        .btn-grey:focus,
        .btn-grey:focus-visible {
            background-color: #7bb4dc !important;
            border-color: #7bb4dc !important;
            color: #fff !important;
            box-shadow: none;
        } 
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light px-3">
            <a class="navbar-brand" href="https://nsns.ca" target="_blank">
                <img src="/images/nsns_logo_new.jpg" alt="NSNS Logo" />
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-lg-0 ms-auto">

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Admin/List">Admins</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Staff/List">Staff</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Report/Index">Reports</a></li>
                    }
                    else if (User.IsInRole("Staff"))
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Specialty/List">Specialties</a></li>
                        <li class="nav-item"><a class="nav-link" href="/City/List">Cities</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Coach/List">Coaches</a></li>
                        <li class="nav-item"><a class="nav-link" href="/PaymentPackage/List">Packages</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Course/List">Courses</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Activity/List">Activities</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/List">Children</a></li>
                    }
                    else if (User.IsInRole("Coach"))
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Coach/ManageCourse">Courses</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Coach/MyCalendar">Calendar</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Coach/MyHours">Hours</a></li>
                    }
                    else if (User.IsInRole("Child"))
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">NSNS Programs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyRegistrations">Registrations</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyConfirmations">Confirmations</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MySchedules">Schedules</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyEnrollmentsHistory">Enrollments</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyCalendar">Calendar</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyBalance">Balance</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Child/MyPayments">Payments</a></li>
                    }

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               href="#"
                               onclick="document.getElementById('logout-form').submit();">
                                Logout (@User.Identity.Name)
                            </a>
                            <form id="logout-form"
                                  asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="d-none"></form>
                        </li>
                    }
                </ul>
            </div>
        </nav>
    </header>

    @{
        string mainClass = "container mt-4 px-3";

        if (ViewContext.RouteData.Values["Controller"]?.ToString() == "Home"
        && ViewContext.RouteData.Values["Action"]?.ToString() == "Index")
        {
            mainClass = "container-fluid mt-4 px-3";
        }
    }

    <main class="@mainClass">
        @RenderBody()
    </main>

    <footer class="text-center bg-light">
        <p class="mb-0">&copy; @DateTime.UtcNow.Year - NSNS</p>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>