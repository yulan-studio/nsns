<form asp-action="Save" method="post" id="specialtyForm">
    <table style="border-collapse: collapse; text-align: left; width: 100%;">
        <tr>
            <td style="padding: 8px; width: 40%">
                <label for="Title">Specialty Name:</label>
            </td>
            <td style="padding: 8px; width: 60%">
                <input asp-for="Title" placeholder="Specialty Name"
                       style="width: 100%;" required />
                <span asp-validation-for="Title" class="text-danger"></span>
                <input type="hidden" asp-for="SpecialtyID" />
            </td>
        </tr>
        <tr>
            <td style="padding: 8px; width: 40%">
                <label for="Description">Description:</label>
            </td>
            <td style="padding: 8px; width: 60%">
                <input asp-for="Description" placeholder="Description"
                       style="width: 100%; height: 50px;" required />
                <span asp-validation-for="Description" class="text-danger"></span>
            </td>
        </tr>
        <tr>
            <td colspan="2" style="text-align: left; padding: 20px 16px 16px 8px;">
                <button type="submit"
                        style="background-color: #ff4d4d; color: white; border: none;
                               padding: 5px 10px; cursor: pointer;">
                    Save
                </button>
                <a href="/Specialty/List"
                   style="background-color: #ddd; color: black; text-decoration: none;
                          padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>
            </td>
        </tr>
    </table>
</form>
