@model Core.ViewModels.LoginViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}

<div class="container mt-4 mb-5">

    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-6 col-lg-4">

            <h2 class="mb-4 text-center">Login</h2>

            <form asp-action="Login" method="post">

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Email:</label>
                    <input type="email"
                           name="Email"
                           value="@Model.Email"
                           class="form-control"
                           placeholder=""
                           required />
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label class="form-label">Password:</label>
                    <input type="password"
                           name="Password"
                           value="@Model.Password"
                           class="form-control"
                           placeholder=""
                           required />
                </div>

                <!-- Remember Me -->
                <div class="form-check mb-3">
                   @*  <input class="form-check-input"
                           type="checkbox"
                           name="RememberMe"
                           @(Model.RememberMe ? "checked" : "") />
                    <label class="form-check-label">
                        Remember Me
                    </label> *@

                   
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">
                            Remember Me
                        </label>
                   
                </div>

                <!-- Login Button -->
                <button type="submit"
                        class="btn btn-primary">
                    Login
                </button>

                <!-- Validation Errors -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="mt-3">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div class="alert alert-danger py-2">
                                @error.ErrorMessage
                            </div>
                        }
                    </div>
                }

            </form>
        </div>
    </div>

    <!-- Bottom Message -->
    <div class="mt-5 pt-4 border-top text-muted">
        <div class="mx-auto" style="max-width: 900px; font-size: 0.95em; line-height: 1.6;">
            To make it easier for you to manage registrations, courses, and activities, we're launching a new management system!
            All children and coaches participating in NorthStar programs will have their own accounts. The system is currently under development and testing—stay tuned!
            <br /><br />
            为方便大家了解报名、课程和活动安排，我们即将启用全新的管理系统。所有参与北极星活动的孩子和教练都将拥有自己的登录账号。目前系统正在开发和测试中，敬请期待，感谢您的支持！
        </div>
    </div>

</div>