@model Core.ViewModels.LoginViewModel

@{
     Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}


<div style="height: 30px;">
   
</div>

<h2>Login</h2>

<div style="height: 20px;">
</div>

<form asp-action="Login" method="post">
 

    <table style="border-collapse: collapse; width: 30%; text-align: left; padding-top: 80px;">
        <tr>
            <td style="padding: 8px;"><label for="email">Email:</label></td>
            <td style="padding: 8px;"><input type="email" name="Email" value="@Model.Email" placeholder="Email" style="width: 100%;" /></td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label for="password">Password:</label></td>
            <td style="padding: 8px;"><input type="password" name="Password" value="@Model.Password" placeholder="Password" style="width: 100%;" /></td>
        </tr>

        <tr>
            <td colspan="2" style="padding: 8px;">
                @* <input type="checkbox" name="RememberMe" value="@Model.RememberMe" /> Remember Me *@
                <input type="checkbox" name="RememberMe" @(Model.RememberMe ? "checked" : "") /> Remember Me
            </td>
        </tr>

        <tr>
            <td colspan="2" style="text-align: left; padding: 20px 16px 16px 8px;">
                <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Login</button>
            </td>
        </tr>

        <tr>
            <td colspan="2" style="text-align: left; padding: 20px 0px 16px 0px;">
                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div class="alert alert-danger">
                            @error.ErrorMessage
                        </div>
                    }
                }
            </td>
        </tr>
    </table>

    <!-- Full-width Message at Bottom -->
    <div style="width: 100%; margin-top: 10px; padding: 30px 10px 10px 10px; border-top: 1px solid #ccc;">
        <div style="max-width: 1400px; margin: auto; font-size: 0.9em; line-height: 1.6; text-align: left; color:darkslategray">
            To make it easier for you to manage registrations, courses, and activities, we're launching a new management system!
            All children and coaches participating in NorthStar programs will have their own accounts. The system is currently under development and testing—stay tuned!
            <br /><br />
            为方便大家了解报名、课程和活动安排，我们即将启用全新的管理系统。所有参与北极星活动的孩子和教练都将拥有自己的登录账号。目前系统正在开发和测试中，敬请期待，感谢您的支持！
        </div>
    </div>
</form>