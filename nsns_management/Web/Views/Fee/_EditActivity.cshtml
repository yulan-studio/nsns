@model Core.ViewModels.FeeEditViewModel

@{
    ViewData["Title"] = "Edit Fee";
}

@* <h2>Edit Fee</h2> *@

@if (Model.IsPaid)
{
    <div class="alert alert-info">
        <strong>This fee has already been paid and cannot be edited.</strong>
    </div>

    <form>
        <table style="border-collapse: collapse; text-align: left; width: 100%;">
            <tr>
                <td style="padding: 8px; width: 20%">
                    <label>PaymentModel:</label>
                </td>
                <td style="padding: 8px; width: 50%">
                   @Model.PaymentModel 
                  
                </td>
            </tr>
            <tr>
                <td style="padding: 8px; width: 20%"><label>Description:</label></td>
                <td style="padding: 8px; width: 50%">@Model.Description</td>
            </tr>
            <tr>
                <td style="padding: 8px; width: 20%"><label>Total Cost:</label></td>
                <td style="padding: 8px; width: 50%">@Model.TotalCost</td>
            </tr>
            <tr>
                <td colspan="2" style="text-align: left; padding: 20px 16px 16px 8px;">
                    <a href="/Child/ManageRegistrations/@Model.ChildID"
                       style="background-color: #ddd; color: black; text-decoration: none;
                                  padding: 5px 10px; border: 1px solid #ccc;">Back</a>
                </td>
            </tr>
        </table>
    </form>
}
@* else if (Model.TotalCost == null)
