else
{
    <form asp-action="EditActivityFee" method="post" id="feeForm">
        <input type="hidden" asp-for="ActivityEnrollmentID" />
        <input type="hidden" asp-for="FeeID" />
        <input type="hidden" asp-for="ChildID" />

        <table style="border-collapse: collapse; text-align: left; width: 100%;">
            <tr>
                <td style="padding: 8px; width: 20%">
                    <label for="PaymentModel">PaymentModel:</label>
                </td>
                <td style="padding: 8px; width: 50%">
                    @Model.PaymentModel
                    <input type="hidden" asp-for="PaymentModel" />
                </td>
            </tr>
           
            <tr>
                <td style="padding: 8px; width: 20%">
                    <label for="Description">Description:</label>
                </td>
                <td style="padding: 8px; width: 50%">
                    <textarea asp-for="Description" placeholder="Description"
                              style="width: 100%; height: 80px;" required>@Model.Description</textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td style="padding: 8px; width: 20%">
                    <label for="TotalCost">Total Cost:</label>
                </td>
                <td style="padding: 8px; width: 50%">
                    <input type="number" asp-for="TotalCost" placeholder="Total Cost"
                           value="@Model.TotalCost" step="0.01" style="width: 100%;" required />
                    <span asp-validation-for="TotalCost" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td colspan="2" style="text-align: left; padding: 20px 16px 16px 8px;">
                    <button type="submit"
                            style="background-color: #ff4d4d; color: white; border: none;
                                       padding: 5px 10px; cursor: pointer;">
                        Save
                    </button>
                    <a href="/Child/Participation/@Model.ChildID?tab=ManageRegistrations"
                       style="background-color: #ddd; color: black; text-decoration: none;
                                  padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>
                </td>
            </tr>
        </table>
    </form>
}