@model Core.ViewModels.FeeEditViewModel

@{
    ViewData["Title"] = "Edit Fee";
}

<h2>Edit Fee</h2>

@if (Model.IsPaid)
{
    <div class="alert alert-info">
        <strong>This fee has already been paid and cannot be edited. </strong>
    </div>

    <dl class="row">
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Total Cost</dt>
        <dd class="col-sm-10">@Model.TotalCost</dd>
    </dl>

    <a href="/Child/ManageRegistrations/@Model.ChildID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Back</a>
}

 else if (Model.TotalCost == null)
{
    <div class="alert alert-info">
        <strong>This fee will be deducted from token in each session.</strong>
    </div>

    <dl class="row">
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Total Cost</dt>
        <dd class="col-sm-10">@Model.TotalCost</dd>
    </dl>


    <a href="/Child/ManageRegistrations/@Model.ChildID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Back</a>
} 
else
{
    <form asp-action="EditCourseFee" method="post">
        <input type="hidden" asp-for="CourseEnrollmentID" />
        <input type="hidden" asp-for="FeeID" />
        <input type="hidden" asp-for="ChildID" />

        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="TotalCost" class="control-label"></label>
            <input asp-for="TotalCost" class="form-control" />
            <span asp-validation-for="TotalCost" class="text-danger"></span>
        </div>

        <button type="submit" style="background-color: #ff4d4d; color: white; padding: 5px 10px; border: none; cursor: pointer;">Save</button>
        <a href="/Child/ManageRegistrations/@Model.ChildID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>
    </form>
}
