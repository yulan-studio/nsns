    <p><strong>Gender:</strong> @Model.Gender</p>
    <p><strong>City:</strong> @(Model.City != null ? Model.City.Name : "N/A")</p>

    <p><strong>Has OAP:</strong> @Model.HasOAP</p>
    <p><strong>Email:</strong> @Model.User.Email</p>
