</table>
    <button type="button" class="btn btn-primary" onclick="addRow()">Add Contact</button>

</form>
 *@



<table>
    @foreach (var ec in Model.EmergencyContacts)
    {
        <tr>
            <td>@ec.ContactName</td>
            <td>@ec.Relationship</td>
            <td>@ec.Phone</td>
            <td>@ec.Email</td>
            <td>
                <form asp-action="DeleteEmergencyContact" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="contactId" value="@ec.EmergencyContactID" />
                    <input type="hidden" name="childId" value="@Model.ChildID" />
                    <button type="submit">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>

<form asp-action="AddEmergencyContact" asp-controller="Child" asp-route-childId="@Model.ChildID"  method="post">
    @Html.AntiForgeryToken()
  @*   <input type="hidden" name="childId" value="@Model.ChildID" /> *@
    <input name="contactName" placeholder="ContactName" />
    <input name="relationship" placeholder="Relationship" />
    <input name="phone" placeholder="Phone" />
    <input name="email" placeholder="Email" />
    <button type="submit">Add Contact</button>
</form>


@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let rowIndex = 1;
        function addRow() {
            let newRow = `
                <tr>
                    <td><input name="EmergencyContacts[${rowIndex}].Name" class="form-control" /></td>
                    <td><input name="EmergencyContacts[${rowIndex}].Relationship" class="form-control" /></td>
                    <td><input name="EmergencyContacts[${rowIndex}].Phone" class="form-control" /></td>
                    <td><input name="EmergencyContacts[${rowIndex}].Email" class="form-control" /></td>
                </tr>`;
            document.getElementById("contact-rows").insertAdjacentHTML("beforeend", newRow);
            rowIndex++;
        }
    </script>
}