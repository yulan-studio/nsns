@model Core.Models.Child

@{
    Layout = null;
}

<h2>Core Information</h2>

<form asp-action="CoreInfo" method="post">
 

    <table style="border-collapse: collapse; width: 50%; text-align: left;">

        <tr>
            <td style="padding: 8px;"><label asp-for="MemberID"></label></td>
            <td style="padding: 8px;">
                @* <input type="text" name="memberID" placeholder="Enter child's Member ID" style="width: 100%;" /> *@
                <input asp-for="MemberID" class="form-control" />
            </td>
        </tr>
        <tr>
            <td style="padding: 8px;"><label asp-for="PrimaryDiagnosis"></label></td>
            <td style="padding: 8px;">
                @* <input type="text" name="memberID" placeholder="Enter child's Member ID" style="width: 100%;" /> *@
                <input asp-for="PrimaryDiagnosis" class="form-control" />
            </td>
        </tr>
        <tr>
            <td style="padding: 8px;"><label asp-for="City"></label></td>
            <td style="padding: 8px;">
                @(Model.City != null ? Model.City.Name : "N/A")
            </td>
        </tr>
        <tr>
            <td style="padding: 8px;"><label asp-for="Address"></label></td>
            <td style="padding: 8px;">
                <input asp-for="Address" class="form-control" />
            </td>
        </tr>
        <tr>
            <td style="padding: 8px;"><label asp-for="OAPAmount"></label></td>
            <td style="padding: 8px;">
                <input asp-for="OAPAmount" type="number" class="form-control" />
            </td>
        </tr>
        <tr>
            <td style="padding: 8px;"><label asp-for="PhotoConsent"></label></td>
            <td style="padding: 8px;">
                <input asp-for="PhotoConsent" type="checkbox" class="form-check-input" />
            </td>
        </tr>
    </table>

   

    <br /><br />
    <button type="submit" class="btn btn-primary">Save</button>
</form>


<div style="margin-bottom: 50px;"></div>

<h4>Emergency Contacts</h4>

@* <form asp-action="EmergencyContacts" method="post">
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Relationship</th>
            <th>Phone</th>
