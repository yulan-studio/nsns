@model Core.ViewModels.ManageParentsViewModel



@{
    Layout = null;
}


<h2>Manage Parents</h2>

<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Name</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Email</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Phone</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Wechat</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Relationship</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var parentChild in Model.Parents)
        {
            if (ViewBag.EditParentId != null && (int)ViewBag.EditParentId == parentChild.ParentID)
            {
                <!-- Edit mode row -->
               
             <tr>
                <td colspan="6">
                    <form asp-action="UpdateParent" asp-controller="Child" method="post" style="display: flex; gap: 10px;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ParentChildID" value="@parentChild.ParentChildID" />
                        <input type="hidden" name="ChildID" value="@parentChild.ChildID" />

                        <input name="Name" value="@parentChild.Parent.Name" required />
                        <input name="Email" value="@parentChild.Parent.Email" type="email" required />
                        <input name="Phone" value="@parentChild.Parent.Phone" />
                        <input name="Wechat" value="@parentChild.Parent.Wechat" />
                        <input name="Relationship" value="@parentChild.Relationship" disabled />

                        <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px;">Save</button>
                        <a href="@Url.Action("MoreInfo", new { childId = parentChild.ChildID, tab = "Parents" })"
                           style="margin-right: 10px; color: #007bff;">Cancel</a>
                    </form>
                </td>
             </tr>
            }
            else
            {
                <!-- Normal row -->
                <tr>
                    <td>@parentChild.Parent.Name</td>
                    <td>@parentChild.Parent.Email</td>
                    <td>@parentChild.Parent.Phone</td>
                    <td>@parentChild.Parent.Wechat</td>
                    <td>@parentChild.Relationship</td>
                    <td>
                        @* <a href="@Url.Action("Parents", new { childId = parentChild.ChildID, editParentId = parentChild.ParentID })" style="margin-right: 10px; color: #007bff;">Edit</a> *@
                        <a href="@Url.Action("MoreInfo", new { childId = parentChild.ChildID, tab = "Parents", editParentId = parentChild.ParentID })"
                           style="margin-right: 10px; color: #007bff;">Edit</a>
                        <form asp-action="DeleteParent" asp-controller="Child" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="parentChildId" value="@parentChild.ParentChildID" />
                            <input type="hidden" name="childId" value="@parentChild.ChildID" />
                            <input type="hidden" name="parentId" value="@parentChild.ParentID" />
                            <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px;">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div style="margin-bottom: 30px;"></div>

<h4>Add Parent</h4>
<form asp-action="AddParent" asp-controller="Child" asp-route-childId="@Model.Child.ChildID" method="post">
    @Html.AntiForgeryToken()
    <input name="Name" placeholder="Name" required />
    <input name="Email" placeholder="Email" type="email" required />
    <input name="Phone" placeholder="Phone" />
    <input name="Wechat" placeholder="Wechat" />
    @* <input name="Relationship" placeholder="Relationship" required /> *@
    <select name="Relationship" placeholder="Relationship" required style="margin-right: 10px;">
        <option value="">-- Select Relationship --</option>
        <option value="Father">Father</option>
        <option value="Mother">Mother</option>
        <option value="Guardian">Guardian</option>

    </select>
    <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px;">Add Parent</button>
</form>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="margin-top:15px;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="margin-top:15px;">
        @TempData["ErrorMessage"]
    </div>
}


