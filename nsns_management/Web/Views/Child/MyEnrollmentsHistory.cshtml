@model Core.ViewModels.EnrollmentsHistoryViewModel

<h2>Enrollments History</h2>




<div style="padding-top: 20px; padding-bottom: 20px">
    <h4 style="color:steelblue">- Courses -</h4>
</div>


<table id="CompletedCourses" style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Course</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Coach</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Location</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled At</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled Hours</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Actual Hours</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
            
        </tr>
    </thead>
    <tbody>
        @if (Model.CompletedCourses!= null && Model.CompletedCourses.Any())
        {
            foreach (var enrollment in Model.CompletedCourses)
            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Course.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@(enrollment.Course.Coach?.Name ?? "N/A")</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Location</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@((enrollment.ScheduledAt.HasValue) ? enrollment.ScheduledAt.Value.ToString("yyyy-MM-dd HH:mm") : "") </td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.ScheduledHours </td>
                    <td style="padding: 8px; border: 1px solid #ddd;">
                        @if (enrollment.ActualHours != null)
                        {


                            <a href="javascript:void(0);" onclick="showNoteModal('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(enrollment.CoachNote))')">
                                @enrollment.ActualHours
                            </a>
                        }

                    </td>


                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Status</td>
                    
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" style="text-align: center; padding: 10px;">No completed courses.</td>
            </tr>
        }

       
    </tbody>
</table>

<div style="padding-top: 20px; padding-bottom: 20px">
    <h4 style="color:steelblue">- Activities -</h4>
</div>

<table id="CompletedActivities" style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Activity</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Description</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Address</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled At</th>

        </tr>
    </thead>
    <tbody>
        @if (Model.CompletedActivities!=null && Model.CompletedActivities.Any())
           
        {
            foreach (var enrollment in Model.CompletedActivities)
            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Description</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Address</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" style="text-align: center; padding: 10px;">No completed activities.</td>
            </tr>
        }


    </tbody>
</table>


<!-- Bootstrap Modal -->
<div class="modal fade" id="noteModal" tabindex="-1" aria-labelledby="noteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="noteModalLabel">Coach Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="noteModalBody">
                <!-- Content will be filled dynamically -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>
<script>
    function showNoteModal(description) {

        var modalBody = document.getElementById('noteModalBody');
        modalBody.textContent = description;

        var modal = new bootstrap.Modal(document.getElementById('noteModal'));
        modal.show();
    }
</script>







