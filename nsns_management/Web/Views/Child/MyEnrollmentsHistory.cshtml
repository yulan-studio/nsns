<h2>Enrollments History</h2>

<!-- ================= COURSES ================= -->
<div class="py-3">
    <h4 style="color:steelblue">- Courses -</h4>
</div>

<div style="padding: 10px 10px 10px 10px; margin: 0px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">

    Records can be sorted by 'Course' or 'Scheduled At'.<br />

    记录可以按课程（Course）或安排时间（Scheduled At）进行排序。



</div>

@* <table class="mobile-stack table table-bordered">
    <thead class="table-light"> *@
<table class="mobile-stack table table-bordered mt-3" >
    <thead class="table-primary">
        <tr>
            @* <th>Course</th> *@

            <th style="padding: 8px; border: 1px solid #ddd; background-color:lightblue">
                <a asp-action="MyEnrollmentsHistory" asp-route-sortOrder="@ViewData["CourseSortParm"]" style="color: black; text-decoration: none; ">
                    Course
                    @if ((string)ViewData["CurrentSort"] == "course")
                    {
                        <span>▲</span>
                    }
                    else if ((string)ViewData["CurrentSort"] == "course_desc")
                    {

                        <span>▼</span>
                    }
                </a>
            </th>
            <th class="desktop-only">Coach</th>
            <th class="desktop-only">Location</th>
           @*  <th>Scheduled At</th> *@
           
            <th style="padding: 8px; border: 1px solid #ddd; background-color:lightblue">
                <a asp-action="MyEnrollmentsHistory" asp-route-sortOrder="@ViewData["ScheduledAtSortParm"]" style="color: black; text-decoration: none; ">
                    Scheduled At
                    @if ((string)ViewData["CurrentSort"] == "scheduledAt")
                    {
                        <span>▲</span>
                    }
                    else if ((string)ViewData["CurrentSort"] == "scheduledAt_desc")
                    {

                        <span>▼</span>
                    }
                </a>
            </th>

            <th class="desktop-only">Scheduled Hours</th>
            <th>Actual Hours</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.CompletedCourses != null && Model.CompletedCourses.Any())
        {
            foreach (var enrollment in Model.CompletedCourses)
            {
                <tr>
                    <td @* data-label="Course" *@>@enrollment.Course.Title</td>
                    <td class="desktop-only" @* data-label="Coach" *@>@(enrollment.Course.Coach?.Name ?? "N/A")</td>
                    <td class="desktop-only" @* data-label="Location" *@>@enrollment.Location</td>
                    <td @* data-label="Scheduled At" *@>
                        @(enrollment.ScheduledAt.HasValue
                                        ? enrollment.ScheduledAt.Value.ToString("yyyy-MM-dd HH:mm")
                                        : "")
            </td>
            <td class="desktop-only" @* data-label="Scheduled Hours" *@>@enrollment.ScheduledHours</td>
            <td @* data-label="Actual Hours" *@>
                @if (enrollment.ActualHours != null)
                        {
                            <a href="javascript:void(0);"
                               onclick="showNoteModal('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(enrollment.CoachNote))')">
                                @enrollment.ActualHours
                            </a>
                        }
                    </td>
                    <td @* data-label="Status" *@>@enrollment.Status</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center p-3">
                    No completed courses.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ================= ACTIVITIES ================= -->
<div class="py-3">
    <h4 style="color:steelblue">- Activities -</h4>
</div>

<table class="mobile-stack table table-bordered mt-3">
    <thead class="table-primary">
        <tr>
            <th>Activity</th>
           @*  <th>Description</th> *@
            <th>Scheduled At</th>
            <th class="desktop-only">Address</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.CompletedActivities != null && Model.CompletedActivities.Any())
        {
            foreach (var enrollment in Model.CompletedActivities)
            {
                <tr>
                    <td @* data-label="Activity" *@>@enrollment.Activity.Title</td>
                  @*   <td data-label="Description">@enrollment.Activity.Description</td> *@
                    <td @* data-label="Scheduled At" *@>
                        @enrollment.Activity.ScheduledAt.ToString("yyyy-MM-dd HH:mm")
                    </td>
                    <td class="desktop-only" @* data-label="Address" *@>@enrollment.Activity.Address</td>
                    
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center p-3">
                    No completed activities.
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ================= MODAL ================= -->
<div class="modal fade" id="noteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Coach Note</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="noteModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showNoteModal(description) {
        document.getElementById('noteModalBody').textContent = description;
        new bootstrap.Modal(document.getElementById('noteModal')).show();
    }
</script>
