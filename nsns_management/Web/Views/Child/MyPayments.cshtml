@model Core.ViewModels.ManagePaymentsViewModel

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style>
    /* Hide desktop table on mobile */
    @@media (max-width: 767px) {
        .desktop-table

    {
        display: none;
    }

    }

    /* Hide mobile cards on desktop */
    @@media (min-width: 768px) {
        .mobile-cards

    {
        display: none;
    }

    }

    .payment-card {
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 15px;
        margin-bottom: 15px;
        background-color: #f8f9fa;
    }

    .payment-label {
        font-weight: 600;
        color: #555;
    }

    .receipt-img {
        max-width: 100%;
        border-radius: 6px;
        margin-top: 5px;
    }
</style>

<h2>Payments History</h2>

<!-- ===================== -->
<!-- DESKTOP TABLE VIEW -->
<!-- ===================== -->
<div class="desktop-table mt-3">
  @*   <table class="table table-bordered align-middle">
        <thead class="table-light"> *@

   @*  <table class="mobile-table" style="border-collapse: collapse; width: 100%; text-align: left;"> *@
    <table class="mobile-stack table table-bordered mt-3">
        <thead class="table-primary">
            <tr>
                <th>Parent</th>
                <th>Token Payment</th>
                <th>Direct Payment</th>
                <th>Amount</th>
                <th>Payment Date</th>
                <th>Screenshot</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Payments.Any())
            {
                foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>@payment.Parent.Name</td>
                        <td>@(payment.PaymentPackage?.Title ?? "")</td>
                        <td>
                            @(payment.Fee != null
                                                ? (payment.Fee.CourseEnrollment != null
                                                ? payment.Fee.CourseEnrollment.Course.Title
                                                : (payment.Fee.ActivityEnrollment != null
                                                ? payment.Fee.ActivityEnrollment.Activity.Title
                                                : ""))
                                                : "")
                </td>
                <td>$@payment.Amount</td>
                <td>@(payment.PaymentDate?.ToString("yyyy-MM-dd") ?? "")</td>
                <td>
                    @if (!string.IsNullOrEmpty(payment.Receipt))
                            {
                                <a href="@payment.Receipt" target="_blank">
                                    <img src="@payment.Receipt" width="100" />
                                </a>
                            }
                            else
                            {
                                <span>No Receipt</span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">No payments found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ===================== -->
<!-- MOBILE CARD VIEW -->
<!-- ===================== -->
<div class="mobile-cards mt-3">
    @if (Model.Payments.Any())
    {
        foreach (var payment in Model.Payments)
        {
            <div class="payment-card">
                <div><span class="payment-label">Parent:</span> @payment.Parent.Name</div>

                <div class="mt-1">
                    <span class="payment-label">Token Payment:</span>
                    @(payment.PaymentPackage?.Title ?? "-")
                </div>

                <div class="mt-1">
                    <span class="payment-label">Direct Payment:</span>
                    @(payment.Fee != null
                                ? (payment.Fee.CourseEnrollment != null
                                ? payment.Fee.CourseEnrollment.Course.Title
                                : (payment.Fee.ActivityEnrollment != null
                                ? payment.Fee.ActivityEnrollment.Activity.Title
                                : "-"))
                                : "-")
        </div>

                <div class="mt-1">
                    <span class="payment-label">Amount:</span>
                    <strong>$@payment.Amount</strong>
                </div>

                <div class="mt-1">
                    <span class="payment-label">Payment Date:</span>
                    @(payment.PaymentDate?.ToString("yyyy-MM-dd") ?? "-")
                </div>

                <div class="mt-2">
                    <span class="payment-label">Receipt:</span><br />
            @if (!string.IsNullOrEmpty(payment.Receipt))
                    {
                        <a href="@payment.Receipt" target="_blank">
                            <img src="@payment.Receipt" class="receipt-img" />
                        </a>
                    }
                    else
                    {
                        <span>No Receipt</span>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center text-muted mt-3">
            No payments found.
        </div>
    }
</div>