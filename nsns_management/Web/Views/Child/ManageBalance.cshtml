<!-- ✅ Form to Add a New Payment -->
<div style="margin: 30px 0; padding: 20px; background-color: #f2f2f2">
    <b>Adjust or Refund Balance</b>
    <div style="margin-bottom: 10px;"></div>
<!-- Adjustment / Refund Form -->
    <form method="post" asp-action="FixBalance" style="margin-top: 20px;">
    <input type="hidden" name="ChildID" value="@Model.ChildID" />

    <table style="width: 100%; border-collapse: collapse;">
        <!-- Select Action Type -->
        <tr>
            <td style="padding: 8px; width: 200px;"><label>Action Type:</label></td>
            <td>
                <input type="radio" id="adjustBalance" name="actionType" value="Adjustment" checked />
                <label for="ajustBalance">Adjust Balance</label>
                &nbsp;&nbsp;
                <input type="radio" id="refundBalance" name="actionType" value="Refund" />
                <label for="refundBalance">Refund</label>
            </td>
        </tr>

        <!-- Amount -->
        <tr>
            <td style="padding: 8px;"><label for="Amount">Amount:</label></td>
            <td>
                <input id="Amount" name="amount" type="number" step="1" required style="width: 20%;" />
               
            </td>
        </tr>

        <!-- Remarks (optional but helpful for logs) -->
        <tr>
            <td style="padding: 8px;"><label for="Remarks">Remarks:</label></td>
            <td>
                <input id="Remarks" name="remarks" type="text" placeholder="Optional note" style="width: 50%;" />
            </td>
        </tr>

        <!-- Submit -->
        <tr>
            <td style="padding: 8px;">
                <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 8px 15px; cursor: pointer; border-radius: 5px;">
                    Submit
                </button>
            </td>
        </tr>
    </table>
</form>
</div>
