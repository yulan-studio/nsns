@model Core.ViewModels.ChildSchedulesToConfirmViewModel
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


<h2>Courses|Activities to Confirm</h2>

<div style="padding-top: 20px; padding-bottom: 20px">
    <h4 style="color:steelblue">- Courses -</h4>
</div>

@if (TempData["SuccessMessage2"] != null)
{

    <div class="alert alert-success">
        @Html.Raw(@TempData["SuccessMessage2"])
    </div>

}

@if (TempData["ErrorMessage2"] != null)
{

    <div class="alert alert-danger">
        @TempData["ErrorMessage2"]
    </div>

}

@{
    bool hasCourseToConfirm = false;
}

@* Group course to confirm *@
@if (Model.CoursesSchedulesToConfirm.Any())
{
    hasCourseToConfirm = true;

    @foreach (var courseSchedulesToConfirm in Model.CoursesSchedulesToConfirm)
    {
        <div style="padding: 10px 20px 10px 20px; margin: 20px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
            <h5>Course: @courseSchedulesToConfirm.Course.Title</h5>



            <strong>Course Type: </strong>  @courseSchedulesToConfirm.Course.CourseType
            <strong> &nbsp; &nbsp; Sessions Count: </strong> @courseSchedulesToConfirm.Course.SessionCount
            <strong> &nbsp; &nbsp;Coach: </strong>   @(courseSchedulesToConfirm.Course.Coach?.Name ?? "N/A")


        </div>

        <div class="mb-3">
            <button id="toggleBtn_@courseSchedulesToConfirm.Course.CourseID"
                    class="btn btn-grey"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#collapseCourse_@courseSchedulesToConfirm.Course.CourseID"
                    aria-expanded="false"
                    aria-controls="collapseCourse_@courseSchedulesToConfirm.Course.CourseID">
                Show Schedules to Confirm
            </button>

            <div id="collapseCourse_@courseSchedulesToConfirm.Course.CourseID" class="collapse mt-2">
                <div class="card card-body">
                    <form method="post" asp-action="UpdateSchedulesToConform">
                        <input type="hidden" name="CourseID" value="@courseSchedulesToConfirm.Course.CourseID" />
                        <input type="hidden" name="Fee.PaymentModel" value="@courseSchedulesToConfirm.Fee.PaymentModel" />
                        <input type="hidden" name="Fee.TotalCost" value="@courseSchedulesToConfirm.Fee.TotalCost" />
                        <input type="hidden" name="Fee.CourseEnrollmentID" value="@courseSchedulesToConfirm.Fee.CourseEnrollmentID" />

                        <table style="border-collapse: collapse; width: 100%; text-align: left;">
                            <thead>
                                <tr style="background-color: #f2f2f2;">
                                    <th style="padding: 8px; border: 1px solid #ddd;" width="10%">Date</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;" width="10%">Start Time</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;" width="10%">End Time</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;" width="15%">Location</th>
                                    <th style="padding: 8px; border: 1px solid #ddd;" width="15%">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (courseSchedulesToConfirm.Schedules.Any())
                                {
                                    @for (int i = 0; i < courseSchedulesToConfirm.Schedules.Count; i++)
                                    {
                                        var schedule = courseSchedulesToConfirm.Schedules[i];
                                        var scheduledAt = schedule.ScheduledAt;
                                        var scheduledHours = schedule.ScheduledHours.HasValue ? (double)schedule.ScheduledHours.Value : 0;
                                        DateTime? endTime = scheduledAt?.AddHours(scheduledHours);

                                        <input type="hidden" name="Schedules[@i].EnrollmentID" value="@schedule.EnrollmentID" />
                                        <tr>
                                            <td style="padding: 8px; border: 1px solid #ddd;">
                                                @(scheduledAt.HasValue? scheduledAt.Value.ToString("yyyy-MM-dd") : "")
                                            </td>
                                            <td style="padding: 8px; border: 1px solid #ddd;">
                                                @(scheduledAt.HasValue? scheduledAt.Value.ToString("HH:mm") : "")
                                            </td>
                                            <td style="padding: 8px; border: 1px solid #ddd;">
                                                @(endTime.HasValue? endTime.Value.ToString("HH:mm") : "")
                                            </td>
                                            <td style="padding: 8px; border: 1px solid #ddd;">@schedule.Location</td>
                                            <td style="padding: 8px; border: 1px solid #ddd;">@schedule.Status</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align: center; padding-top: 10px;">
                                            There are currently no schedules waiting for your confirmation.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <br />
                        @if (!courseSchedulesToConfirm.Fee.IsPaid)
                        {
                        <div style="padding: 10px 20px; margin: 20px 0; border: 1px solid #ddd; background-color: #f8f9fa;">
                            Total Cost: @courseSchedulesToConfirm.Fee.TotalCost<br />
                            @(courseSchedulesToConfirm.Fee.Description)<br />
                        </div>
                        }

                        <div style="padding: 20px; margin: 20px 0; border: 1px solid #ddd; background-color: #f8f9fa;">
                            Please click 'Confirm' to complete your course registration.<br />
                            请点击"Confirm"以完成课程注册。<br /><br />
                            <button type="submit" name="actionType" value="Confirm"
                                    class="btn btn-primary mt-2">
                                Confirm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>




        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const collapseId = 'collapseCourse_@courseSchedulesToConfirm.Course.CourseID';
                const buttonId = 'toggleBtn_@courseSchedulesToConfirm.Course.CourseID';

                const collapseElement = document.getElementById(collapseId);
                const buttonElement = document.getElementById(buttonId);

                collapseElement.addEventListener('show.bs.collapse', function () {
                    buttonElement.textContent = 'Hide Schedules';
                });

                collapseElement.addEventListener('hide.bs.collapse', function () {
                    buttonElement.textContent = 'Show Schedules to confirm';
                });
            });
        </script>



     
    }
}



@* Private course to confirm *@
@if (Model.PrivateCoursesToConfirm != null && Model.PrivateCoursesToConfirm.Any())
{
    hasCourseToConfirm = true;

    @foreach (var enrollment in Model.PrivateCoursesToConfirm)
    {


        <form method="post" asp-action="UpdateCourseToConform">
            <input type="hidden" name="CourseID" value="@enrollment.CourseID" />
            <input type="hidden" name="EnrollmentID" value="@enrollment.EnrollmentID" />
            <input type="hidden" name="TotalCost" value="@enrollment.TotalCost" />
            <input type="hidden" name="PaymentModel" value="@enrollment.PaymentModel" />
            @* <table class="mobile-stack table table-bordered mt-2" style="border-collapse: collapse; width: 100%; text-align: left;"> *@
            <table class="mobile-stack table" style="border-collapse: collapse; width: 100%; text-align: left;">
                <thead class="table-primary">
                    <tr>
                        <th style="padding: 8px; border: 1px solid #ddd;">Course</th>
                        <th style="padding: 8px; border: 1px solid #ddd;">Description</th>
                        <th style="padding: 8px; border: 1px solid #ddd;">Status</th>

                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Title</td>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Description</td>
                        <td style="padding: 8px; border: 1px solid #ddd;@(enrollment.Status == "Canceled" ? "color: red" : "")">@enrollment.Status</td>

                    </tr>
                </tbody>
            </table>
            <br />

            <div  style="padding: 20px 20px 20px 20px; margin: 0px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">

                Total Cost: $@enrollment.TotalCost<br />
                @(enrollment.PaymentDescription)<br />

            </div>



            <div @* class="alert alert-danger" *@  style="padding: 20px 20px 20px 20px; margin: 20px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
                Please click 'Confirm' to complete your course registration.<br />
                请点击"Confirm"以完成课程注册。<br /><br />
                <button type="submit" name="actionType" value="Confirm" class="btn btn-primary mt-2">Confirm</button>

            </div>
        </form>


    }

}



@if(!hasCourseToConfirm)
{
    <div style="text-align: left; padding-top: 10px; padding-bottom: 20px;">No course available for confirmation.</div>
}

<div style="padding-top: 20px; padding-bottom: 20px">
    <h4 style="color:steelblue">- Activities -</h4>
</div>

@if (TempData["SuccessMessage3"] != null)
{

    <div class="alert alert-success">
        @Html.Raw(@TempData["SuccessMessage3"])
    </div>

}

@if (TempData["ErrorMessage3"] != null)
{

    <div class="alert alert-danger">
        @* @TempData["ErrorMessage3"] *@

    </div>

}
@if (Model.ActivitiesToConfirm != null && Model.ActivitiesToConfirm.Any())
{

    @foreach (var enrollment in Model.ActivitiesToConfirm)
    {


        <form method="post" asp-action="UpdateActivityToConform">
            <input type="hidden" name="ActivityID" value="@enrollment.ActivityID" />
            <input type="hidden" name="EnrollmentID" value="@enrollment.EnrollmentID" />
            <input type="hidden" name="TotalCost" value="@enrollment.TotalCost" />
            <input type="hidden" name="PaymentModel" value="@enrollment.PaymentModel" />
            <table style="border-collapse: collapse; width: 100%; text-align: left;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th style="padding: 8px; border: 1px solid #ddd;">Activity</th>
                        <th style="padding: 8px; border: 1px solid #ddd;">Description</th>
                        <th style="padding: 8px; border: 1px solid #ddd;">Address</th>
                        <th style="padding: 8px; border: 1px solid #ddd;">Scheduled At</th>
                        @*  <th style="padding: 8px; border: 1px solid #ddd;">Cost</th> *@
                        <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
                        @*  <th style="padding: 8px; border: 1px solid #ddd;">Actions</th> *@
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Title</td>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Description</td>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Address</td>
                        <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                        @*  <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.TotalCost</td> *@
                        <td style="padding: 8px; border: 1px solid #ddd;@(enrollment.Status == "Canceled" ? "color: red" : "")">@enrollment.Status</td>

                    </tr>
                </tbody>
            </table>
            <br />

            <div @* class="alert alert-danger" *@  style="padding: 10px 20px 10px 20px; margin: 20px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">

                Total Cost: @enrollment.TotalCost<br />
                @(enrollment.PaymentDescription)<br />

            </div>



            <div @* class="alert alert-danger" *@  style="padding: 20px 20px 20px 20px; margin: 20px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
                Please click 'Confirm' to complete your activity registration.<br />
                请点击"Confirm"以完成活动注册。<br /><br />
                <button type="submit" name="actionType" value="Confirm" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Confirm</button>

            </div>
        </form>


    }

}
else
{

    <div style="text-align: left; padding-top: 30px;">No activity available for confirmation.</div>



}













