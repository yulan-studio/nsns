@model Core.Models.Child

<div>
    <p><strong>Name:</strong> @Model.Name</p>
    <p><strong>Birth Date:</strong> @(Model.BirthDate.HasValue ? Model.BirthDate.Value.ToString("yyyy-MM-dd") : "N/A")</p>
    <p><strong>Gender:</strong> @Model.Gender</p>
    <p><strong>City:</strong> @(Model.City != null ? Model.City.Name : "N/A")</p>
</div>
<a href="/Child/List" style="display: inline-block; margin-top: 20px; background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Back to Children List</a>
<div style="border-top: 2px solid #ddd; margin: 20px 0;"></div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" href="#" data-url="/Child/CoreInfo/@Model.ChildID">Core Member Information</a></li>
    <li class="nav-item"><a class="nav-link active" href="#" data-url="/Child/ManageParents/@Model.ChildID">Manage Parents</a></li>
    <li class="nav-item"><a class="nav-link" href="#" data-url="/Child/ManageRegistrations/@Model.ChildID">Manage Registration</a></li>
    @*<li class="nav-item"><a class="nav-link" href="#" data-url="/Course/List?childId=@Model.Id">Courses</a></li> *@
</ul>

<!-- Content Area -->
<div id="contentArea" class="border p-3">
    <!-- Subpage will load here -->
</div>


@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // alert("Page ready!");
            // Load first tab by default
            $("#contentArea").load($("ul.nav-tabs a.active").data("url"));

            // Handle clicks
            $("ul.nav-tabs a").on("click", function (e) {
                e.preventDefault();
                $("ul.nav-tabs a").removeClass("active");
                $(this).addClass("active");

                var url = $(this).data("url");
                $("#contentArea").load(url);
            });
        });
    </script>
}



