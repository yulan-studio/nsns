                                Remove
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" style="text-align: center; padding: 10px;">No activities enrolled.</td>
            </tr>
        }

        @if (TempData["SuccessMessage2"] != null)
        {
            <tr>
                <td colspan="7">
                    <div class="alert alert-success">
                        @TempData["SuccessMessage2"]
                    </div>
                </td>
            </tr>
        }

        @if (TempData["ErrorMessage2"] != null)
        {
            <tr>
                <td colspan="7">
                    <div class="alert alert-danger">
                        @TempData["ErrorMessage2"]
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>



<div id="activityFeeModal" class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Activity Fee</h5>
                <button type="button" class="close" data-bs-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="activityModalContent">
                <!-- The Edit form will be loaded here dynamically -->
            </div>
        </div>
    </div>
</div>

