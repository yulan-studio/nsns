        }
    </select>
        <div style="margin-top: 10px; margin-bottom:20px;">
        <!-- Select Payment Model -->
        <label @* for="PaymentModel2" *@>Payment Model:</label>
            <select id="paymentModel" name="paymentModel" required onchange="toggleActivityFeeInput(this);updateDescription(this);">
