</form>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script> 
<script>
        function fetchCoursesBySpecialty(specialtyId) {
            if (!specialtyId) {
                document.getElementById('courseId').innerHTML = '<option value="">-- Select Course --</option>';
                return;
            }

            fetch(`/Child/GetCoursesBySpecialty?specialtyId=${specialtyId}`)
                .then(response => response.json())
                .then(data => {
                    const courseDropdown = document.getElementById('courseId');
                    courseDropdown.innerHTML = '<option value="">-- Select Course --</option>';
                    data.forEach(course => {
                        const option = document.createElement('option');
                        option.value = course.courseID;
                        option.text = course.title;
                        option.setAttribute("data-course-type", course.courseType);
                        courseDropdown.add(option);
                    });
                });
    }


    let isGroupClass = false;

    function checkIfGroupClass(courseId) {
        const courseDropdown = document.getElementById("courseId");
        const selectedOption = courseDropdown.options[courseDropdown.selectedIndex];
        const courseType = selectedOption.getAttribute("data-course-type");

        if (courseType === "Group") {
            isGroupClass = true;
        } else {
            isGroupClass = false;
        }

        toggleCourseFeeInput();
    }

    function toggleCourseFeeInput(element) {
        const parentDiv = element.closest("div"); // Find nearest div section
        const paymentModelDropdown = parentDiv.querySelector("[name='paymentModel']");
        const paymentModel = paymentModelDropdown.value;
        const feeSection = document.getElementById("feeSection");

        if (paymentModel === "Direct") {
            feeSection.style.display = "block";
            document.getElementById("totalCost").setAttribute("required", "required");
        }
        else if (paymentModel === "Token") {
            if (isGroupClass) {
                feeSection.style.display = "block";
                document.getElementById("totalCost").setAttribute("required", "required");



            }
            else {
                feeSection.style.display = "none";
                document.getElementById("totalCost").removeAttribute("required");
            }
        }
        else if (paymentModel === "OAP") {
            
                feeSection.style.display = "block";
                document.getElementById("totalCost").setAttribute("required", "required");
         
        }
        else {
            feeSection.style.display = "none";
            document.getElementById("totalCost").removeAttribute("required");
        }


    }


    function loadEditCourseFeeForm(courseEnrollmentId) {
        $.get("/Fee/EditCourseFee/" + courseEnrollmentId, function (data) {
            //alert(data);
            $("#courseModalContent").html(data);
            $("#courseFeeModal").modal("show");
        });
    }

    function loadEditActivityFeeForm(activityEnrollmentId) {
        $.get("/Fee/EditActivityFee/" + activityEnrollmentId, function (data) {
            //alert(data);
            $("#activityModalContent").html(data);
            $("#activityFeeModal").modal("show");
        });
    }



    function toggleActivityFeeInput(element) {
        const parentDiv = element.closest("div"); // Find nearest div section
        const paymentModelDropdown = parentDiv.querySelector("[name='paymentModel']");
        //const paymentModel = document.getElementById("paymentModel").value;
        const paymentModel = paymentModelDropdown.value;
        const feeSection = document.getElementById("activityFeeSection");

        if (paymentModel === "Direct") {
            feeSection.style.display = "block";
            document.getElementById("totalCost").setAttribute("required", "required");
        }
        else if (paymentModel === "Token") {

                feeSection.style.display = "block";
                document.getElementById("totalCost").setAttribute("required", "required");
        }
        else if (paymentModel === "OAP") {

                feeSection.style.display = "block";
                document.getElementById("totalCost").setAttribute("required", "required");
        }
        else {
                feeSection.style.display = "none";
                document.getElementById("totalCost").removeAttribute("required");
        }
    }



        function updateDescription(element) {
        const parentDiv = element.closest("div"); // Find nearest div section
        const paymentModelDropdown = parentDiv.querySelector("[name='paymentModel']");
        const totalCostInput = parentDiv.querySelector("[name='totalCost']");
        const descriptionInput = parentDiv.querySelector("[name='description']");

        const paymentModel = paymentModelDropdown.value;
        const totalCost = totalCostInput.value.trim();

        if (paymentModel === "Token" && totalCost && totalCost !== "0") {
            descriptionInput.value = `Use Token - $${totalCost} will be deducted from your balance once confirmed.`;
        } else if (paymentModel === "Direct" && totalCost && totalCost !== "0") {
            descriptionInput.value = `Please email transfer $${totalCost} to accounting@ncoatoronto.ca, and send screenshot to customer service.`;
        } 
        else if (paymentModel === "OAP" && totalCost && totalCost !== "0") {
            descriptionInput.value = `Please email transfer $${totalCost} to info@nutcrackertherapy.ca, and send screenshot to customer service.`;
        }
        // else if (paymentModel === "Token" && totalCost === null) {
        //     descriptionInput.value = "To be charged in sessions";
        // }
        else {
            descriptionInput.value = "Free";
        }
    }

</script>