    /* ===== Desktop default ===== */
    table.mobile-stack {
        width: 100%;
        border-collapse: collapse;
    }

    table.mobile-stack th,
    table.mobile-stack td {
        padding: 10px;
        border: 1px solid #ddd;
        vertical-align: top;
    }

    /* ===== Mobile stacked cards ===== */
    @@media (max-width: 767px) {
    /* .balance-table {
        display: none;
    } */

        
        .desktop-only {
            display: none !important;
        }
    }
       

  /*   table.mobile-stack thead
    {
        display: none;
    } 

    table.mobile-stack,
    table.mobile-stack tbody,
    table.mobile-stack tr,
    table.mobile-stack td {
        display: block;
        width: 100%;
    }

        table.mobile-stack tr {
            margin-bottom: 16px;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            background: #fff;
        }

        table.mobile-stack td {
