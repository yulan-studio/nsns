<!-- ✅ Table Showing Already Registered Courses -->
<h3 style="margin-bottom:20px">Registered Courses | Completed Courses</h3>


<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Course</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Course Type</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Specialty</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Coach</th>
         @*    <th style="padding: 8px; border: 1px solid #ddd;">Hourly Cost</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Hourly Cost(No funding)</th> *@
            <th style="padding: 8px; border: 1px solid #ddd;">Is Active</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Session Count</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Schedculed</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Completed</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Canceled</th>
           @*  <th style="padding: 8px; border: 1px solid #ddd;">Request To Reschedule</th> *@
            <th style="padding: 8px; border: 1px solid #ddd;">Request To Leave</th>
            <th style="padding: 8px; border: 1px solid #ddd;">On Leave</th>
         @*    <th style="padding: 8px; border: 1px solid #ddd;">Actions</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Group Sessions</th> *@
        </tr>
    </thead>
    <tbody>
        @if (Model.CourseEnrollments.Any())
        {

            foreach (var enrollment in Model.CourseEnrollments)

            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.CourseType</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.SpecialtyName</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.CoachName</td>
                    
               @*      <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.HourlyCost</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.HourlyCost2</td> *@
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.IsActive</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Status</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.SessionCount</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;">@enrollment.ScheduledSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;">@enrollment.CompletedSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;">@enrollment.CanceledSessions</td>
                  @*   <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC; color:@((enrollment.RequestToRescheduleSessions > 0) && enrollment.CourseType == "Group"? "red" : "black");" >@enrollment.RequestToRescheduleSessions</td> *@
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC; background-color:@(enrollment.RequestToLeaveSessions > 0 ? "#FFDBF6" : "#EDFDFC");">@enrollment.RequestToLeaveSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;">@enrollment.OnLeaveSessions</td>
 
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="12" style="text-align: center; padding: 10px;">No private courses enrolled.</td>
            </tr>
        }

    </tbody>
</table>




<div style="margin-bottom: 50px;"></div>

<!-- ✅ Table Showing Already Enrolled Activities -->
<h3 style="margin-bottom:20px;">Registered Activities | Canceled Activities</h3>

<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Activity Title</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Address</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled Date</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Cost</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.ActivityEnrollments.Any())
        {
            foreach (var enrollment in Model.ActivityEnrollments)
            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Address</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.ScheduledAt.ToString("yyyy-MM-dd")</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Cost</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Status</td>
               
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" style="text-align: center; padding: 10px;">No activities enrolled.</td>
            </tr>
        }

    
    </tbody>
</table>

