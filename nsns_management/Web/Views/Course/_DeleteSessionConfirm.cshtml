



@model Core.Models.CourseEnrollment

<h2 style="margin-bottom: 30px;">Confirm Delete</h2>
<p>Are you sure you want to delete this session?</p>

<div>
    <p><strong>Scheduled At：</strong> @(Model.ScheduledAt?.ToString("yyyy-MM-ddTHH:mm"))</p>
    <p><strong>Scheduled Hours：</strong> @Model.ScheduledHours</p>
    <p><strong>Location：</strong> @Model.Location</p>
    <p><strong>Staff Note：</strong> @Model.StaffNote</p>
</div>

<form id="sessionForm">
   @*  <input type="hidden" name="enrollmentId" value="@Model.EnrollmentID" />
    <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Confirm Delete</button> *@
    <button type="button" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;" onclick="deleteSession(@Model.EnrollmentID)">Delete</button>
    <a href="/Course/ManageSessions/@Model.CourseID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>
</form>