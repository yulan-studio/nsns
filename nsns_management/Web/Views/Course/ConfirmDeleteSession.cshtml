
@model Core.Models.CourseEnrollment

<h2 style="margin-bottom: 30px;">Confirm Delete</h2>
<p>Are you sure you want to delete this session?</p>

<div>
    <p><strong>Scheduled At：</strong> @Model.ScheduledAt</p>
    <p><strong>Scheduled Hours：</strong> @Model.ScheduledHours</p>
    <p><strong>Location：</strong> @Model.Location</p>
    <p><strong>Note：</strong> @Model.StaffNote</p>
</div>

<form method="post" action="/Course/DeleteSessionConfirmed" method="post">
    <input type="hidden" name="courseId" value="@Model.EnrollmentID" />
    <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Confirm Delete</button>
    <a href="/Course/Schedules/@Model.EnrollmentID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>
</form>