@* <form method="post" asp-action="AddSession" asp-controller="Course"> *@

@model CourseEnrollment

<form id="sessionForm">
    <input type="hidden" name="enrollmentId" value="@Model.EnrollmentID" />

    <div style="margin-bottom: 10px;">
        <strong>Scheduled At:</strong><br />
        <input type="datetime-local" name="scheduledAt" value="@(Model.ScheduledAt?.ToString("yyyy-MM-ddTHH:mm"))" disabled style="width: 40%; padding: 5px;" />
    </div> 

   <div style="margin-bottom: 10px;">
        <strong>Scheduled Hours:</strong><br />
        <input type="number" step="0.5" min="0.5" name="scheduledHours" value="@Model.ScheduledHours" disabled style="width: 40%; padding: 5px;" />
    </div> 

    <div style="margin-bottom: 10px;">
        <strong>Status:</strong><br />
        <input type="text" name="status" value="@Model.Status" required style="width: 40%; padding: 5px;" />
    </div>

    <div style="margin-bottom: 10px;">
        <strong>Location:</strong><br />
        <input type="text" name="location" value="@Model.Location"  style="width: 40%; padding: 5px;" />
    </div>

    <div style="margin-bottom: 10px;">
        <strong>NSNS Note:</strong><br />
        <textarea name="staffNote" rows="3" style="width: 40%; padding: 5px;">@Model.StaffNote</textarea>
    </div>

    <button onclick="saveSession()" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Save</button>
    <a href="/Course/ManageSessions/@Model.CourseID" style="background-color: #ddd; color: black; text-decoration: none; padding: 5px 10px; border: 1px solid #ccc;">Cancel</a>

   @*  <button type="submit" style="background-color: #2198D4; color: white; padding: 8px 15px; border: none; cursor: pointer; border-radius: 4px;">Add Session</button> *@
</form>