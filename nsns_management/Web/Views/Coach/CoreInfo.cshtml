@model Core.Models.Coach

@{
    Layout = null;
}


<h2>Core Information</h2>

<form asp-action="CoreInfo" method="post">


    <table style="border-collapse: collapse; width: 50%; text-align: left;">

        <tr>
            <td style="padding: 8px;"><label asp-for="MemberID">Member ID</label></td>
            <td style="padding: 8px;">
                @* <input type="text" name="memberID" placeholder="Enter child's Member ID" style="width: 100%;" /> *@
                <input asp-for="MemberID" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="PreferedName">Chosen Name</label></td>
            <td style="padding: 8px;">
                <input asp-for="PreferedName" class="form-control" />
            </td>
        </tr>
       
        <tr>
            <td style="padding: 8px;"><label asp-for="Address">Address</label></td>
            <td style="padding: 8px;">
                <input asp-for="Address" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="PostCode">PostCode</label></td>
            <td style="padding: 8px;">
                <input asp-for="PostCode" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="Bank"></label></td>
            <td style="padding: 8px;">
                <input asp-for="Bank" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="Transit"></label></td>
            <td style="padding: 8px;">
                <input asp-for="Transit" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="Account"></label></td>
            <td style="padding: 8px;">
                <input asp-for="Account" class="form-control" />
            </td>
        </tr>

        <tr>
            <td style="padding: 8px;"><label asp-for="Status"></label></td>
            @* <td style="padding: 8px;">
                <input asp-for="Status" class="form-control" />
            </td> *@
            <td style="padding: 8px;">
                <select name="Status" style="width: 50%;">
                    <option value="">-- Select Status --</option>
                    <option value="Citizen" selected="@(Model.Status == "Citizen" ? "selected" : null)">Citizen</option>
                    <option value="PR" selected="@(Model.Status == "PR" ? "selected" : null)">PR</option>
                    <option value="WP" selected="@(Model.Status == "WP" ? "selected" : null)">WP</option>
                    <option value="SP" selected="@(Model.Status == "SP" ? "selected" : null)">SP</option>
                    <option value="Unknown" selected="@(Model.Status == "Unknown" ? "selected" : null)">Unknown</option>
                </select>
            </td>
        </tr>
       
     
        <tr>
            <td style="padding: 8px;"><label asp-for="PhotoConsent">Photo Consent</label></td>
            <td style="padding: 8px;">
                <input asp-for="PhotoConsent" type="checkbox" class="form-check-input" />
            </td>
        </tr>
    </table>



    <br /><br />
    <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Save</button>
</form>


<div style="margin-bottom: 50px;"></div>

<h4>Emergency Contacts</h4>








<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Name</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Relationship</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Phone</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Email</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var ec in Model.EmergencyContacts)
        {
            <tr>
                <td style="padding: 8px; border: 1px solid #ddd;">@ec.ContactName</td>
                <td style="padding: 8px; border: 1px solid #ddd;">@ec.Relationship</td>
                <td style="padding: 8px; border: 1px solid #ddd;">@ec.Phone</td>
                <td style="padding: 8px; border: 1px solid #ddd;">@ec.Email</td>
                <td style="padding: 8px; border: 1px solid #ddd;">
                    <form asp-action="DeleteEmergencyContact" asp-route-contactId="@ec.EmergencyContactID" method="post">
                        @Html.AntiForgeryToken()
                        @* <input type="hidden" name="contactId" value="@ec.EmergencyContactID" /> *@
                        <input type="hidden" name="coachId" value="@Model.CoachID" />
                        <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div style="margin-bottom: 50px;"></div>

<form asp-action="AddEmergencyContact" asp-controller="Coach" asp-route-coachId="@Model.CoachID" method="post">
    @Html.AntiForgeryToken()
    @*   <input type="hidden" name="childId" value="@Model.ChildID" /> *@
    <input name="contactName" placeholder="ContactName" />
    <input name="relationship" placeholder="Relationship" />
    <input name="phone" placeholder="Phone" />
    <input name="email" placeholder="Email" />
    <button type="submit" style="background-color: #ff4d4d; color: white; border: none; padding: 5px 10px; cursor: pointer;">Add Contact</button>
</form>

<div style="margin-bottom: 50px;"></div>

