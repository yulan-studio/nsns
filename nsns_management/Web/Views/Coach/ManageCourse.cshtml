
 @model Core.ViewModels.ManageCourseViewModel

<h2>Manage Courses</h2>

<div style="padding: 10px 20px 10px 20px; margin: 20px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
    At this stage, coaches are requested to complete the original coaching time log in parallel and ensure that both records are consistent. <br />
    在现阶段，请教练同时填写原来的教练时间登记表，且两份记录保持一致。<br />
     <span style="align-content:end"><a href="https://sites.google.com/view/nsns-coach-attendance/%E9%A6%96%E9%A1%B5" target="_blank">NSNS Coach Attendance</a></span>
</div>

@foreach (var specialty in Model.Specialties)
{
    <div style="margin: 40px 0; padding: 10px; background-color: #f8f9fa; border-left: 5px solid #1B7BAB;">
        <div style="margin: 0; padding: 10px 0; color: #1B7BAB;"><strong>@specialty.SpecialtyTitle</strong></div>
    </div>

    @foreach (var course in specialty.Courses)
    {
        <div style="margin: 20px 0; padding: 15px; border-radius: 5px; border: 1px solid #ddd; background-color: #fff;">

            <div style="margin: 0 0 10px; color: #333;"><strong>Course:</strong> @($"{course.CourseTitle}" + (course.CourseDescription != null ? $" | {course.CourseDescription}" : ""))</div>
            @if(course.SessionCount!=null)
            {
                <div style="margin: 0 0 10px; color: #333;"><strong>Session Count:</strong> @course.SessionCount</div>
            }

            <table style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 14px;">
                <thead>
                    <tr style="background-color: #1B7BAB; color: white;">
                        <th style="padding: 10px; border: 1px solid #ddd;">Child Name</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Gender</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">City</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Birthday</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Registration Date</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Scheduled</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Request to Reschedule</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Deleted</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Completed</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Schedules</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Enrollments</th>
                    </tr>
                </thead>
                <tbody>
                    @if (course.RegisteredChildren.Any())
                    {
                        foreach (var child in course.RegisteredChildren)
                        {
                            <tr style="background-color: #f9f9f9;">
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.Name</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.Gender</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.City</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@(child.BirthDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.RegisteredDate.ToString("yyyy-MM-dd")</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.Scheduled</td>
                                <td style="padding: 10px; border: 1px solid #ddd; background-color:@(child.RequestToReschedule > 0 ? "#FFDBF6" : "#f9f9f9")">@child.RequestToReschedule</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.Deleted</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">@child.Completed</td>
                                <td style="padding: 10px; border: 1px solid #ddd;">
                                    <a href="/Coach/ManageSchedules/@child.ChildID?courseId=@course.CourseID&enrollmentId=@child.EnrollmentID">
                                        Manage
                                    </a>
                                </td>
                                <td style="padding: 10px; border: 1px solid #ddd;">
                                    <a href="/Coach/ManageEnrollments/@child.ChildID?courseId=@course.CourseID">
                                        Manage
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" style="text-align: center; padding: 15px; background-color: #f8f9fa; font-weight: bold;">
                                No registered children for this course.
                            </td>
                        </tr>
                    }


                    @if (TempData["SuccessMessage"] != null)
                    {
                        <tr>
                            <td colspan="11">
                                <div class="alert alert-success">
                                    @TempData["SuccessMessage"]
                                </div>
                            </td>
                        </tr>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <tr>
                            <td colspan="11">
                                <div class="alert alert-danger">
                                    @TempData["ErrorMessage"]
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
