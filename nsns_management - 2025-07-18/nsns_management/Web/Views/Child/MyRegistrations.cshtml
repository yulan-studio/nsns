


@* <script src="/js/registrations.js"></script> *@
@model Core.ViewModels.ManageRegisterationsViewModel


<h2>Registerations</h2>


<!-- ✅ Table Showing Already Registered Courses -->
<div style="padding-top: 20px; padding-bottom: 20px">
    <h5>Registered Courses</h5>
</div>
<div style="padding: 10px 10px 10px 10px; margin: 0px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
    All registered and completed courses <br />
    所有已注册和已完成的课程<br />
    <span style="color:cadetblue">To view upcoming course session schedules, please check the <a href="/Child/MySchedules">Schedules</a> section. For completed sessions, please refer to the <a href="/Child/MyEnrollmentsHistory">Enrollments</a> section.<br/>
        如需查看即将开始的课程安排，请前往 <a href="/Child/MySchedules">Schedules</a> 页面。已完成的课程请查看 <a href="/Child/MyEnrollmentsHistory">Enrollments</a> 页面。
    </span>
</div>
<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Course</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Course Type</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Is Active</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Specialty</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Coach</th>
            
            <th style="padding: 8px; border: 1px solid #ddd;">Hourly Cost</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Hourly Cost(No Funding)</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Session Count</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Completed</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Canceled</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Request To Reschedule</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Request To Leave</th>
            <th style="padding: 8px; border: 1px solid #ddd;">On Leave</th>
            
            <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
         
        </tr>
    </thead>
    <tbody>
        @if (Model.CourseEnrollments.Any())
        {

            foreach (var enrollment in Model.CourseEnrollments)

            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.CourseType</td>
                    <td style="padding: 8px; border: 1px solid #ddd;@(enrollment.IsActive == false ?"color: red":"")">@enrollment.IsActive</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.SpecialtyName</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.CoachName</td>
                    
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.HourlyCost</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.HourlyCost2</td>
                    
                    
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.SessionCount</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC; color:@(enrollment.ScheduledSessions > 0 ? "red" : "black");">@enrollment.ScheduledSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;">@enrollment.CompletedSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;@(@enrollment.CanceledSessions>0 ?"color: red":"")">@enrollment.CanceledSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;@(enrollment.RequestToRescheduleSessions > 0 ?"color: red":"")">@enrollment.RequestToRescheduleSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC;@(@enrollment.RequestToLeaveSessions>0 ?"color: red":"")">@enrollment.RequestToLeaveSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd; background-color:#EDFDFC; @(@enrollment.OnLeaveSessions>0 ?"color: red":"")">@enrollment.OnLeaveSessions</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Status</td>

                 
                </tr>
            }
           
        }
        else
        {
            <tr>
                <td colspan="15" style="text-align: center; padding: 10px;">No courses enrolled.</td>
            </tr>
        }

        
    </tbody>
</table>






<!-- ✅ Table Showing Already Enrolled Activities -->
<div style="padding-top: 20px; padding-bottom: 20px">
<h5>Registered Activities </h5>
</div>
<div style="padding: 10px 10px 10px 10px; margin: 0px 0px 20px 0px; border: 1px solid #ddd; background-color: #f8f9fa;">
    All registered activities that are not yet completed<br/>
    所有已注册但尚未完成的活动<br/>
    <span style="color:cadetblue">For completed activities, please refer to the <a href="/Child/MyEnrollmentsHistory">Enrollments</a> section.<br/>
        已完成的活动请查看 <a href="/Child/MyEnrollmentsHistory">Enrollments</a> 页面。
    </span>


</div>
<table style="border-collapse: collapse; width: 100%; text-align: left;">
    <thead>
        <tr style="background-color: #f2f2f2;">
            <th style="padding: 8px; border: 1px solid #ddd;">Activity</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Description</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Address</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Scheduled At</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Cost</th>
            <th style="padding: 8px; border: 1px solid #ddd;">Status</th>
           @*  <th style="padding: 8px; border: 1px solid #ddd;">Actions</th> *@
        </tr>
    </thead>
    <tbody>
        @if (Model.ActivityEnrollments.Any())
        {
            foreach (var enrollment in Model.ActivityEnrollments)
            {
                <tr>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Title</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Description</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Address</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td style="padding: 8px; border: 1px solid #ddd;">@enrollment.Activity.Cost</td>
                    <td style="padding: 8px; border: 1px solid #ddd;@(enrollment.Activity.Status == "Canceled" ?"color: red":"")">@enrollment.Status</td>
                @*     <td style="padding: 8px; border: 1px solid #ddd;">
                        <form method="post" action="/Child/UnregisterActivity">
                            <input type="hidden" name="enrollmentId" value="@enrollment.EnrollmentID" />
                            <input type="hidden" name="childId" value="@enrollment.ChildID" />
                            <button type="submit" style="background-color: #ff4d4d; color: white; padding: 5px 10px; border: none; cursor: pointer;">
                                Remove
                            </button>
                        </form>
                    </td> *@
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" style="text-align: center; padding: 10px;">No activities enrolled.</td>
            </tr>
        }

      
    </tbody>
</table>

